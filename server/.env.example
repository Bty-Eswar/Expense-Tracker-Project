# ========================
# Server Environment Variables
# ========================
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file — only this .example file

PORT=5000

# MongoDB Connection (added in Phase 2)
MONGO_URI=your_mongodb_atlas_connection_string_here

# JWT Secret Key (added in Phase 3)
# Use a long, random string — never share this
JWT_SECRET=your_super_secret_jwt_key_here

# JWT Expiry
JWT_EXPIRES_IN=7d

# Node environment
NODE_ENV=development
